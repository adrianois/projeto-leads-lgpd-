# Configuração de Supabase
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>

# Segurança
ADMIN_API_KEY=<sua-chave-segura-de-admin>
ALLOWED_ORIGINS=http://localhost:3000,https://seublog.com,https://www.seublog.com

# Configuração de email Nodemailer
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu-email@example.com
EMAIL_PASS=sua-senha-de-email
EMAIL_FROM=notificacoes@example.com
ALERT_EMAIL_TO=seu-email-de-alertas@example.com

# Configuração de deploy
PORT=3000
