# Configuração de banco de dados Supabase/Postgres
DATABASE_URL=postgres://<usuario>:<senha>@<host>:5432/<database>

# Configuração de email Nodemailer
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu-email@example.com
EMAIL_PASS=sua-senha-de-email
EMAIL_FROM=notificacoes@example.com
ALERT_EMAIL_TO=seu-email-de-alertas@example.com

# Configuração de deploy
PORT=3000
